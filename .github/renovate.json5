{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended", "helpers:pinGitHubActionDigests"],
  schedule: ["* * 1 * *"],
  nix: {
    enabled: true,
  },
  separateMajorMinor: false,
  ignoreDeps: ["@types/sortablejs"], // we use a static version
  packageRules: [
    {
      groupName: "python dependencies",
      groupSlug: "python",
      matchManagers: ["pep621"],
    },
    {
      matchUpdateTypes: ["major"],
      matchDepNames: ["Django"], // commonly breaks other dependencies requiring async changes
      groupName: "Django major",
      dependencyDashboardApproval: true,
    },
    {
      matchManagers: ["npm"],
      matchUpdateTypes: ["patch"],
      enabled: false,
    },
    {
      matchManagers: ["npm"],
      matchUpdateTypes: ["patch", "minor"],
      matchDepNames: ["sass"],  // causes deprecation warnings in bootstrap
      enabled: false
    },
    {
      groupName: "node dependencies",
      groupSlug: "node",
      matchManagers: ["npm"],
    },
    {
      groupName: "github actions",
      groupSlug: "actions",
      matchManagers: ["github-actions"],
    },
    {
      groupName: "ubuntu & python upgrade",
      groupSlug: "ubuntu",
      matchDepNames: ["ubuntu", "python"],
      dependencyDashboardApproval: true, // manual update when deployment is updated
    },
    {
      groupName: "nix flakes",
      groupSlug: "nix",
      matchManagers: ["nix"],
      schedule: ["* * 1 */3 *"],
    },
  ],
}
